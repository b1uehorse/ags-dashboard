#!/usr/bin/env python3
# eww-tweak — live-крутка размеров дашборда прямо на Betrayer.
# Запускать как floating окно Hyprland: bind = SUPER, T, exec, eww-tweak
# Значения сохраняются в ~/.local/share/eww-tweak/values.json

import json
import os
import subprocess
import tkinter as tk
from pathlib import Path

# tkinter требует X11 — используем XWayland
os.environ.setdefault("DISPLAY", ":0")

EWW_CFG = os.path.expanduser("~/.config/eww/dashboard")
STATE = Path.home() / ".local/share/eww-tweak/values.json"

# (defvar-name, min, max, step, default)
KNOBS = [
    ("profile-h",     100, 500, 10, 290),
    ("ccu-h",          60, 300, 10, 130),
    ("sticker-h",      60, 500, 10, 280),
    ("sysbar-h",      100, 500, 10, 290),
    ("clock-h",        60, 300, 10, 130),
    ("task-h",         60, 500, 10, 280),
    ("music-h",       100, 500, 10, 290),
    ("placeholder-h", 100, 600, 10, 410),
    ("col-w-narrow",  150, 400, 10, 200),
    ("col-w-wide",    150, 400, 10, 240),
    ("tile-gap",        0,  40,  2,   0),
]


def load_state():
    if STATE.exists():
        try:
            return json.loads(STATE.read_text())
        except Exception:
            pass
    return {}


def save_state(values):
    STATE.parent.mkdir(parents=True, exist_ok=True)
    STATE.write_text(json.dumps(values, indent=2))


def push(name, value):
    subprocess.Popen(
        ["eww", "-c", EWW_CFG, "update", f"{name}={int(value)}"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        env={**os.environ, "XDG_RUNTIME_DIR": f"/run/user/{os.getuid()}"},
    )


def main():
    state = load_state()
    values = {}
    vars_tk = {}
    labels = {}

    root = tk.Tk()
    root.title("eww-tweak")
    root.resizable(False, False)

    def commit(name, v):
        v = int(float(v))
        values[name] = v
        labels[name].config(text=str(v))
        push(name, v)
        save_state(values)

    def bump(name, delta, lo, hi):
        v = max(lo, min(hi, values[name] + delta))
        vars_tk[name].set(v)
        commit(name, v)

    for name, lo, hi, step, default in KNOBS:
        init = state.get(name, default)
        values[name] = init

        row = tk.Frame(root, pady=2)
        row.pack(fill="x", padx=10)

        tk.Label(row, text=name, width=15, anchor="w",
                 font=("monospace", 10)).pack(side="left")

        tk.Button(row, text="−", width=2,
                  command=lambda n=name, s=step, l=lo, h=hi: bump(n, -s, l, h)
                  ).pack(side="left")

        v = tk.IntVar(value=init)
        vars_tk[name] = v
        tk.Scale(row, from_=lo, to=hi, orient="horizontal", variable=v,
                 showvalue=False, length=260,
                 command=lambda val, n=name: commit(n, val)
                 ).pack(side="left", padx=4)

        tk.Button(row, text="+", width=2,
                  command=lambda n=name, s=step, l=lo, h=hi: bump(n, s, l, h)
                  ).pack(side="left")

        lbl = tk.Label(row, text=str(init), width=5, anchor="e",
                       font=("monospace", 10))
        lbl.pack(side="left")
        labels[name] = lbl

        # синхронизируем eww со сохранённым состоянием при старте
        push(name, init)

    root.mainloop()


if __name__ == "__main__":
    main()
