#!/usr/bin/env bash
# open_apps — лончер по флагу. Просто запускает приложение в фоне.
# Никаких close-all — дашборд пусть висит, не нужно его закрывать при каждом клике.
set -u
cmd="xdg-open"

case "${1:-}" in
    --nautilus) nautilus & ;;
    --firefox)  firefox & ;;
    --telegram) telegram-desktop & ;;
    --code)     code & ;;
    --spotify)  kitty -e ncspot & ;;
    --discord)  discord & ;;
    --github)   $cmd "https://github.com" & ;;
    --reddit)   $cmd "https://reddit.com" & ;;
    *)
        echo "usage: $0 --{nautilus|firefox|telegram|code|spotify|discord|github|reddit}" >&2
        exit 1 ;;
esac
