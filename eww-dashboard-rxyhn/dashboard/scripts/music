#!/bin/sh

Cover=/tmp/cover.png
bkpCover=~/.config/eww/dashboard/assets/fallback.png

# ncspot регистрируется в MPRIS как "ncspot"
Control=""
[ -n "$(pgrep ncspot)" ] && Control="ncspot"

_pc() {
    [ -z "$Control" ] && return 1
    playerctl --player="$Control" "$@" 2>/dev/null
}

title() {
    t=$(_pc metadata --format "{{title}}")
    echo "${t:-Nothing Playing}"
}

artist() {
    a=$(_pc metadata --format "{{artist}}")
    echo "${a:-Offline}"
}

statusicon() {
    s=$(_pc status)
    case "$s" in
        Playing) echo "" ;;
        Paused)  echo "" ;;
        *)       echo "" ;;
    esac
}

cover() {
    url=$(_pc metadata mpris:artUrl)
    if [ -n "$url" ]; then
        # ncspot уже даёт i.scdn.co, sed на всякий случай
        url=$(echo "$url" | sed 's/open.spotify.com/i.scdn.co/g')
        if curl -sf "$url" -o "$Cover" 2>/dev/null; then
            echo "$Cover"
            return
        fi
    fi
    cp "$bkpCover" "$Cover"
    echo "$Cover"
}

songtime() {
    [ -z "$Control" ] && { echo "0"; return; }
    pos=$(_pc position)
    len=$(_pc metadata --format "{{mpris:length}}")
    [ -z "$pos" ] || [ -z "$len" ] || [ "$len" = "0" ] && { echo "0"; return; }
    # процент 0-100 для шкалы прогресса
    awk "BEGIN { printf \"%.0f\", ($pos * 1000000 / $len) * 100 }"
}

case $1 in
    next)       _pc next          ;;
    previous)   _pc previous      ;;
    toggle)     _pc play-pause    ;;
    title)      title             ;;
    artist)     artist            ;;
    statusicon) statusicon        ;;
    coverloc)   cover             ;;
    songtime)   songtime          ;;
    *)          echo "Usage: music next|previous|toggle|title|artist|statusicon|coverloc|songtime" ;;
esac
