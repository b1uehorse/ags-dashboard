;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;								Widgets Section's								  ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;


;;  Profile Widgets
(defwidget profile []
    (box :orientation "v"
		 :space-evenly "false"
		 :class "profile"
		 :style "min-height: ${profile-h}px;"
    (box :orientation "h"
		 :space-evenly "false" 
    (box :class "pfp"))
    (box :orientation "v" :space-evenly "false"  
    (box :class "pfptxt" :valign "center" {NAME})
    (box :class "subpfptxt" :halign "center" {UNAME})
		)
	)
)

;; Sysbar: 2√Ч3 grid –Љ–µ—В—А–Є–Ї. –Ъ–∞–ґ–і–∞—П —П—З–µ–є–Ї–∞ вАФ –Є–Ї–Њ–љ–Ї–∞ + bar + –Ј–љ–∞—З–µ–љ–Є–µ.
;; –Ф–∞–љ–љ—Л–µ –Є–Ј –µ–і–Є–љ–Њ–≥–Њ JSON `metrics` (—Б–Љ. _variables.yuck).
(defwidget metric-cell [icon label value unit ?class]
  (box :class "metric-cell ${class ?: ''}"
       :orientation "v"
       :space-evenly false
       :spacing 2
       :hexpand true
       :halign "fill"
    (box :orientation "h" :space-evenly false :spacing 6
      (label :class "metric-icon" :text icon)
      (label :class "metric-label" :text label :halign "start" :hexpand true)
      (label :class "metric-value" :text "${value}${unit}" :halign "end"))
    (scale :class "metric-bar" :min 0 :max 100 :value value :active false)))

(defwidget sysbar []
  (box :class "sysbar"
       :orientation "v"
       :space-evenly false
       :spacing 8
       :hexpand true
       :halign "fill"
       :style "min-height: ${sysbar-h}px;"
    (box :orientation "h" :space-evenly true :homogeneous true :spacing 10
      (metric-cell :icon "" :label "cpu"  :value {metrics.cpu}  :unit "%"  :class "m-cpu")
      (metric-cell :icon "у∞НЫ" :label "ram"  :value {metrics.ram}  :unit "%"  :class "m-ram"))
    (box :orientation "h" :space-evenly true :homogeneous true :spacing 10
      (metric-cell :icon "у∞Нє" :label "gpu"  :value {metrics.gpu}  :unit "%"  :class "m-gpu")
      (metric-cell :icon "у∞ШЪ" :label "vram" :value {metrics.vram} :unit "%"  :class "m-vram"))
    (box :orientation "h" :space-evenly true :homogeneous true :spacing 10
      (metric-cell :icon "" :label "cpu¬∞" :value {metrics.cpu_t} :unit "¬∞" :class "m-ctemp")
      (metric-cell :icon "" :label "gpu¬∞" :value {metrics.gpu_t} :unit "¬∞" :class "m-gtemp"))))


;;  Clock Widgets
(defwidget clock []
	(box	:class "time"
			:orientation "v"
			:space-evenly "false"
			:valign "center"
			:hexpand true
			:halign "fill"
			:style "min-height: ${clock-h}px;"
	(box 	:orientation "h"
			:class "date"
			:space-evenly "false"
	(label	:class "hour"
			:text "${hour}")
	(label	:class "separator-clock"
			:text ":")		
	(label	:class "min"
			:text "${minute}"))
	(box	:orientation "h"
			:space-evenly "false"
			:halign "center"
	(label	:class "day"
			:text "${date}"))
	)	
)


;;  Music Widgets
(defwidget music []
	(box 	:class "music-player"
			:orientation "v"
		 	:space-evenly "false"
		 	:halign "fill"
		 	:hexpand true
		 	:style "min-height: ${music-h}px;"
	(box 	:class "album_art" 
		 	:style "background-image: url('${art}');")
	(box 	:orientation "v" 
		 	:space-evenly "false"
		 	:halign "center"
		 	:spacing 10 
	(label  :class "artist"
		 	:limit-width 15
		 	:text artist)
 	(label  :class "song"
		 	:limit-width 20
		 	:text title) 
	(box 	:orientation "h"  
		 	:space-evenly "false"
			:halign "center"
			:spacing 35
			(button :class "btn_prev" :onclick "~/.config/eww/dashboard/scripts/music previous" (label :xalign 0.5 :halign "center" :text "вПЃ"))
			(button :class "btn_play" :onclick "~/.config/eww/dashboard/scripts/music toggle" (label :xalign 0.5 :halign "center" :text playpause))
			(button :class "btn_next" :onclick "~/.config/eww/dashboard/scripts/music next" (label :xalign 0.5 :halign "center" :text "вП≠")))
	(box    :orientation "h"
			:class "metric-player"
			:space-evenly "false"
			(scale  :min 0
					:max 101
					:active "false"
					:value {songtime != "" ? "${songtime}" : "0"}
				)       
			)	
		)
	)
)


;; Quotes Widgets
(defwidget quotes [] 
	(box 	:class "quote" 
		 	:orientation "h" 
			:halign "center"
		 	:spacing 0 
		 	:space-evenly "false"
			:height 253
	(box 	:orientation "v" 
		 	:spacing 0 
		 	:space-evenly "false" 
	(label 	:class "quote-text" 
			:halign "center" 
			:wrap "true"
			:text "\"${quote_text}\"")
	(label 	:class "quote-author" 
			:halign "center" 
			:wrap "true"
			:text quote_author)
		)
	)
)

;; Applications Widgets
(defwidget app[]
	(box	:orientation "v"
			:class "applications"
			:space-evenly "true"
			:halign "center"
			:valign "fill"
			:vexpand true
			:spacing 12
	(button :class "app-nautilus" :halign "center" :valign "center"
			:tooltip "Files (Nautilus)"
			:onclick "~/.config/eww/dashboard/scripts/open_apps --nautilus &" (label :xalign 0.5 :halign "center" :text "пБЉ"))
	(button :class "app-telegram" :halign "center" :valign "center"
			:tooltip "Telegram"
			:onclick "~/.config/eww/dashboard/scripts/open_apps --telegram &" (label :xalign 0.5 :halign "center" :text "пЛЖ"))
	(button :class "app-code" :halign "center" :valign "center"
			:tooltip "VSCode"
			:onclick "~/.config/eww/dashboard/scripts/open_apps --code &" (label :xalign 0.5 :halign "center" :text "оЬМ"))
	(button :class "app-firefox" :halign "center" :valign "center"
			:tooltip "Firefox"
			:onclick "~/.config/eww/dashboard/scripts/open_apps --firefox &" (label :xalign 0.5 :halign "center" :text "пЙ©"))
	(button :class "app-github" :halign "center" :valign "center"
			:tooltip "GitHub"
			:onclick "~/.config/eww/dashboard/scripts/open_apps --github &" (label :xalign 0.5 :halign "center" :text "пВЫ"))
	(button :class "app-spotify" :halign "center" :valign "center"
			:tooltip "Spotify"
			:onclick "~/.config/eww/dashboard/scripts/open_apps --spotify &" (label :xalign 0.5 :halign "center" :text "пЖЉ"))
	)
)

;; Weather Widgets
(defwidget weather [] 
	(box 	:class "weather" 
		 	:orientation "v" 
		 	:space-evenly "false"
		 	:halign "center" 
	(box 	:orientation "v" 
		 	:space-evenly "false"
	(label 	:class "weather-day"
			:text "${day}")
	(box 	:class "weather-icon" 
		 	:style "color: ${weather-hex}" {weather-icon}))
	(box 	:orientation "v" 
		 	:space-evenly "false" 
	(box 	:orientation "h"
			:class "weather-stat"
	     	:halign "center" 
	(label 	:wrap "true"
			:limit-width 15
			:text "${weather-stat}"))
	(box 	:orientation "h" 
			:halign "center"
	(label 	:class "temp-region"
			:text "${temperature} in ${weather-city}, ${weather-country}")) 
		)
	)
)

;; Task Widgets
(defwidget task-list[]
	(box 	:orientation "v"
		 	:space-evenly "false"
		 	:valign "center"
	(box	:class "appointment"
			:orientation "h"
			:space-evenly "false"
	(label  :class "appointment-label"
			:text "Next: ")
	(label  :class "appointment-text"
			:text next_appointment)
	(label  :class "appointment-label"
			:text " in ")
    (label  :class "appointment-text-time"
			:text next_appointment_time))
	(box 	:class "task-list-box"
			:orientation "v"
	(box 	:class "todo"
		 	:orientation "h"
		 	:space-evenly "false"
			:spacing 20
	(label 	:class "tasklabel-todo"
			:text "пЭЄ")
	(label  :class "todo-text"
			:text "${todo-apri-num} high priority, ${todo-total} total"))
	(box 	:class "uptime"
		 	:orientation "h"
		 	:space-evenly "false"
			:spacing 20
		(label 	:class "tasklabel-time"
				:text "пЩП")
		(label  :class "uptime-text"
				:text "${uptime} uptime"))
		(box	:class "mem-usage"
				:orientation "h"
				:space-evenly "false"
				:spacing 20
		(label 	:class "tasklabel-mem"
				:text "пЛЫ")
		(label  :class "mem-usage"
				:text "${mem-usage} used"))

		(box	:class "disk-usage"
			:orientation "h"
			:space-evenly "false"
			:spacing 20
		(label 	:class "tasklabel"
				:text "пВ†")
		(label  :class "disk-usage"
				:text "${disk-usage} free")))

	(box	:orientation "h"
			:space-evenly "false"
			:class "powermenu"
			:spacing 45
			(button :class "poweroff" :tooltip "Shutdown"
			:onclick "systemctl poweroff &" "пАС")
			(button :class "reboot" :tooltip "Reboot"
			:onclick "systemctl reboot &" "пА°")
			(button :class "lock" :tooltip "Lock"
			:onclick "hyprlock &" "пА£")
			(button :class "exit" :tooltip "Logout Hyprland"
			:onclick "hyprctl dispatch exit &" "пВЛ")
			(button :class "close" :tooltip "Close dashboard"
			:onclick "eww -c $HOME/.config/eww/dashboard close dashboard &" "пАН"))
))
(defwidget task[]
	(box :orientation "h"
		 :space-evenly "false"
		 :hexpand true
		 :halign "fill"
		 :class "task"
		 :style "min-height: ${task-h}px;"
	(box :class "task-list"
		(task-list))
	)
)

;; QuickCmd вАФ display-only. –Ч–∞–њ—Г—Б–Ї –Є–Ј –ї—О–±–Њ–≥–Њ —В–µ—А–Љ–∞: `qc "–Ї–Њ–Љ–∞–љ–і–∞"`
;; –§–Њ–Ї—Г—Б –і–∞—И–±–Њ—А–і –љ–µ –Ї—А–∞–і—С—В, —В–∞–Ї –Ї–∞–Ї –љ–µ—В (input).
(defwidget quickcmd []
	(box :class "tile quickcmd"
	     :orientation "v"
	     :space-evenly "false"
	     :vexpand true
	     :spacing 6
		(box :orientation "h" :space-evenly "false" :spacing 8
			(label :class "qc-prompt" :text "вЭѓ")
			(label :class "qc-input-display"
			       :text "${cmd-input != '' ? cmd-input : 'qc \"command\" –≤ —В–µ—А–Љ–Є–љ–∞–ї–µ'}"
			       :halign "start" :hexpand true
			       :limit-width 40))
		(revealer :transition "slidedown"
		          :duration "150ms"
		          :reveal {cmd-out != ""}
			(label :class "qc-out"
			       :text cmd-out
			       :halign "start"
			       :wrap true
			       :limit-width 40))))

;; Photo frame вАФ —Б—В–∞—В–Є—З–љ–∞—П –Ї–∞—А—В–Є–љ–Ї–∞ –Є–Ј assets/frame.png. –Ь–µ–љ—П–µ—В—Б—П –Ї–Њ–Љ–∞–љ–і–Њ–є `frame /path/to.jpg`
(defwidget photo-frame []
	(box :class "tile frame-tile"
	     :orientation "v"
	     :space-evenly "false"
		(box :class "frame-img"
		     :style "background-image: url('/home/bekh/.config/eww/dashboard/assets/frame.png');")))

;; ccu вАФ —А–∞—Б—Е–Њ–і Claude Code –Ј–∞ —Б–µ—Б—Б–Є—О/–љ–µ–і–µ–ї—О. –Ч–љ–∞—З–µ–љ–Є—П –њ—Г—И–∞—В—Б—П —Б –Љ–∞–Ї–∞.
(defwidget ccu-tile []
	(box :class "tile ccu-tile"
	     :orientation "v"
	     :space-evenly "false"
	     :spacing 6
	     :style "min-height: ${ccu-h}px;"
		(box :orientation "h" :space-evenly "false" :spacing 6
			(label :class "ccu-icon" :text "у∞£З")
			(label :class "ccu-title" :text "claude usage" :halign "start" :hexpand true))
		(box :orientation "v" :space-evenly "false" :spacing 4
			(box :orientation "h" :space-evenly "false" :spacing 6
				(label :class "ccu-label" :text "session" :halign "start" :hexpand true)
				(label :class "ccu-pct"   :text "${ccu-session-pct}%"))
			(scale :class "ccu-bar" :min 0 :max 100 :value ccu-session-pct :active false)
			(label :class "ccu-eta" :text ccu-session-eta :halign "end")
			(box :orientation "h" :space-evenly "false" :spacing 6
				(label :class "ccu-label" :text "week" :halign "start" :hexpand true)
				(label :class "ccu-pct"   :text "${ccu-week-pct}%"))
			(scale :class "ccu-bar" :min 0 :max 100 :value ccu-week-pct :active false)
			(label :class "ccu-eta" :text ccu-week-eta :halign "end"))))

;; Sticker вАФ —В–Њ–ї—М–Ї–Њ —З—В–µ–љ–Є–µ. –Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—М —А–µ–і–∞–Ї—В–Є—А—Г–µ—В —З–µ—А–µ–Ј `sticker "..."` –≤ —В–µ—А–Љ–µ
(defwidget sticker []
	(box :class "tile sticker-tile"
	     :orientation "v"
	     :space-evenly "false"
	     :style "min-height: ${sticker-h}px;"
	     :spacing 4
		(box :orientation "h" :space-evenly "false" :spacing 6
			(label :class "sticker-icon" :text "")
			(label :class "sticker-title" :text "note" :halign "start" :hexpand true))
		(label :class "sticker-body"
		       :text sticker-text
		       :halign "start"
		       :wrap true
		       :limit-width 40)))

;; Oscillo вАФ ¬Ђ–ї–Є–љ–Є—П¬ї –Њ—Б—Ж–Є–ї–ї–Њ–≥—А–∞—Д–∞: 60 —В–Њ–љ–Ї–Є—Е –±–∞—А–Њ–≤, —П–Ї–Њ—А–љ—Л–µ –≤ —Ж–µ–љ—В—А,
;; cava smoothing waves=1 –і–µ–ї–∞–µ—В –Є—Е –љ–µ–њ—А–µ—А—Л–≤–љ–Њ–є –≤–Њ–ї–љ–Њ–є
(defwidget oscillo []
	(box :class "tile oscillo"
	     :orientation "v"
	     :space-evenly "false"
		(box :class "oscillo-line"
		     :orientation "h"
		     :space-evenly "true"
		     :valign "center"
		     :halign "fill"
		     :spacing 1
			(for v in oscillo-bars
				(box :class "oscillo-bar"
				     :valign "center"
				     :style "min-height: ${v + 2}px;")))))

;; Placeholder-—В–∞–є–ї –≤–Љ–µ—Б—В–Њ oscillo+quickcmd. –°—Г–Љ–Љ–∞—А–љ–∞—П –≤—Л—Б–Њ—В–∞ –Њ–±–Њ–Є—Е,
;; —З—В–Њ–±—Л –љ–µ –ї–Њ–Љ–∞—В—М –≤–µ—А—В–Є–Ї–∞–ї—М–љ—Л–є —А–Є—В–Љ –њ—А–∞–≤–Њ–є –Ї–Њ–ї–Њ–љ–Ї–Є. –І—В–Њ –Ј–і–µ—Б—М –±—Г–і–µ—В вАФ –њ–Њ–Ї–∞ tbd.
(defwidget placeholder []
	(box :class "tile placeholder"
	     :orientation "v"
	     :space-evenly "false"
	     :hexpand true
	     :halign "fill"
	     :style "min-height: ${placeholder-h}px;"
		(label :class "placeholder-text"
		       :text "placeholder"
		       :halign "center"
		       :valign "center")))

;; Main WIdgets
;; Layout: —В—А–Є –≥–ї–∞–≤–љ—Л–µ –Ї–Њ–ї–Њ–љ–Ї–Є + ¬Ђ–ї–∞–±–∞¬ї —Б–њ—А–∞–≤–∞ –њ–µ—А–µ–і app-column
;; Layout –њ–Њ —А–µ—Д–µ—А–µ–љ—Б—Г rxyhn: 4 –Ї–Њ–ї–Њ–љ–Ї–Є + app-rail
(defwidget col-left []
	(box :orientation "v" :space-evenly "false" :class "side-col"
	     :style "min-width: ${col-w-narrow}px;"
	     :spacing {tile-gap}
		(profile)
		(ccu-tile)
		(sticker)))

(defwidget col-mid []
	(box :orientation "v" :space-evenly "false"
	     :spacing {tile-gap}
		(sysbar)
		(clock)
		(task)))

(defwidget col-right []
	(box :orientation "v" :space-evenly "false" :class "side-col"
	     :style "min-width: ${col-w-wide}px;"
	     :spacing {tile-gap}
		(music)
		(placeholder)))

(defwidget dashboard[]
	(box :orientation "h" :class "dashboard" :space-evenly "false"
	     :halign "center" :valign "center"
		(col-left)
		(col-mid)
		(col-right)))
